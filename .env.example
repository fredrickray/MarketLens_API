NODE_ENV=development
PORT=4000
MONGODB_URI=mongodb://127.0.0.1:27017/marketlens
JWT_SECRET=change-me-min-16-chars-long
JWT_EXPIRES_IN=7d
SESSION_SECRET=change-me-session-min-16-chars

# Optional: comma-separated origins. Leave unset to reflect any origin (dev only).
# CORS_ORIGINS=http://localhost:3000,https://app.example.com

# Login lockout (optional; defaults shown)
# MAX_LOGIN_ATTEMPTS=5
# LOGIN_COOLDOWN_MINUTES=15

# Email OTP (optional; defaults shown)
# MAX_OTP_ATTEMPTS=5
# OTP_TTL_MINUTES=15

# Email: leave SMTP_HOST empty to skip sending (logs only). Set for real delivery.
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# MAIL_FROM=noreply@yourdomain.com

# Google OAuth (optional). All three required for /api/v1/auth/google. Callback must match Google Console.
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_CALLBACK_URL=http://localhost:4000/api/v1/auth/google/callback
# After Google login, browser is redirected here with ?code=...&expires_in=... (short-lived server code).
# Then POST /api/v1/auth/oauth/exchange { "code" } returns JWT JSON and sets HTTP-only access cookie.
# GOOGLE_OAUTH_SUCCESS_REDIRECT=http://localhost:3000/oauth/google

# OAuth exchange codes (Google callback → SPA; default 600 seconds)
# OAUTH_EXCHANGE_CODE_TTL_SECONDS=600

# HTTP-only JWT cookie name (also accepted by GET /api/v1/auth/me if sent with credentials)
# ACCESS_TOKEN_COOKIE_NAME=ml_access_token
