NODE_ENV=development
PORT=4000
MONGODB_URI=mongodb://127.0.0.1:27017/marketlens
JWT_SECRET=change-me-min-16-chars-long
JWT_EXPIRES_IN=7d
SESSION_SECRET=change-me-session-min-16-chars

# Optional: comma-separated origins. Leave unset to reflect any origin (dev only).
# CORS_ORIGINS=http://localhost:3000,https://app.example.com

# Login lockout (optional; defaults shown)
# MAX_LOGIN_ATTEMPTS=5
# LOGIN_COOLDOWN_MINUTES=15

# Email OTP (optional; defaults shown)
# MAX_OTP_ATTEMPTS=5
# OTP_TTL_MINUTES=15

# Email: leave SMTP_HOST empty to skip sending (logs only). Set for real delivery.
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# MAIL_FROM=noreply@yourdomain.com

# Google OAuth (optional). All three required for /api/v1/auth/google. Callback must match Google Console.
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_CALLBACK_URL=http://localhost:4000/api/v1/auth/google/callback
# After Google login, browser is redirected here with ?code=...&expires_in=... (short-lived server code).
# Then POST /api/v1/auth/oauth/exchange { "code" } returns JWT JSON and sets HTTP-only access cookie.
# GOOGLE_OAUTH_SUCCESS_REDIRECT=http://localhost:3000/oauth/google

# OAuth exchange codes (Google callback → SPA; default 600 seconds)
# OAUTH_EXCHANGE_CODE_TTL_SECONDS=600

# HTTP-only JWT cookie name (also accepted by GET /api/v1/auth/me if sent with credentials)
# ACCESS_TOKEN_COOKIE_NAME=ml_access_token

# Redis (optional — Phase 2 wires the client; leave unset to skip)
# REDIS_URL=redis://127.0.0.1:6379
# REDIS_KEY_PREFIX=marketlens:

# ML service (FastAPI). Omit URL in development to use mock predictions.
# ML_SERVICE_URL=http://localhost:8000
# ML_SERVICE_API_KEY=
# ML_SERVICE_TIMEOUT_MS=30000
# ML_SERVICE_MAX_RETRIES=2
# ML_PREDICT_PATH=/predict
# ML_SERVICE_MOCK=true

# Market data providers (Phase 2)
# MARKET_DATA_PROVIDER=finnhub
# FINNHUB_API_KEY=
# ALPHA_VANTAGE_API_KEY=
# MARKET_SEARCH_CACHE_TTL_SECONDS=300
# MARKET_OVERVIEW_CACHE_TTL_SECONDS=60
# MARKET_WARM_SYMBOLS=AAPL,MSFT,GOOGL,AMZN,NVDA
# MARKET_CACHE_REFRESH_CRON=*/15 * * * *
# Without API keys, Yahoo + mock fallback are used automatically.
# MARKET_HISTORY_DAYS=60
# MARKET_HISTORY_CACHE_TTL_SECONDS=3600

# ML analysis cache & confidence thresholds (Phase 3)
# ML_PREDICTION_CACHE_TTL_SECONDS=300
# ML_MIN_BUY_CONFIDENCE=0.6
# ML_MIN_AVOID_CONFIDENCE=0.55

# Compliance & audit (Phase 4)
# COMPLIANCE_VOLATILITY_WARNING_PCT=5
# COMPLIANCE_INFORMATIONAL_CONFIDENCE_MAX=0.5
# COMPLIANCE_AUDIT_RETENTION_DAYS=365
# COMPLIANCE_AUDIT_HISTORY_LIMIT=20

# News (Phase 5) — uses FINNHUB_API_KEY when set; otherwise mock fallback
# NEWS_PROVIDER=finnhub
# NEWS_CACHE_TTL_SECONDS=600
# NEWS_DEFAULT_DAYS=7
# NEWS_DEFAULT_LIMIT=20
# NEWS_MAX_LIMIT=50
# NEWS_SYNC_CRON=0 */6 * * *

# Alerts (Phase 6) — requires JWT auth
# APP_PUBLIC_URL=http://localhost:3000
# ALERTS_COOLDOWN_MINUTES=60
# ALERTS_MAX_PER_USER=25
# ALERTS_EVAL_CRON=*/5 * * * *

# Users & guests (Phase 7)
# APP_PUBLIC_URL=http://localhost:3000
# GUEST_SESSION_TTL_DAYS=7
# GUEST_RATE_LIMIT_PER_MINUTE=40
# AUTH_RATE_LIMIT_PER_MINUTE=120
